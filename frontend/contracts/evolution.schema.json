{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "EvolutionEvent",
    "type": "object",
    "required": [
        "id",
        "agent_id",
        "timestamp",
        "event_type",
        "description"
    ],
    "properties": {
        "id": {
            "type": "string"
        },
        "agent_id": {
            "type": "string"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time"
        },
        "event_type": {
            "type": "string",
            "enum": [
                "created",
                "updated",
                "memory_pruned",
                "consensus_shift"
            ]
        },
        "description": {
            "type": "string"
        }
    },
    "additionalProperties": false
}