{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://mantlesentinel.ai/contracts/alert.schema.json",
    "title": "Mantle Sentinel Alert",
    "type": "object",
    "required": [
        "id",
        "timestamp",
        "source",
        "category",
        "severity",
        "message"
    ],
    "properties": {
        "id": {
            "type": "string",
            "description": "Unique alert identifier"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time"
        },
        "source": {
            "type": "string",
            "minLength": 1
        },
        "category": {
            "type": "string",
            "enum": [
                "security",
                "infrastructure",
                "operations"
            ]
        },
        "severity": {
            "type": "string",
            "enum": [
                "low",
                "medium",
                "high",
                "critical"
            ]
        },
        "message": {
            "type": "string",
            "minLength": 1
        },
        "metadata": {
            "type": "object",
            "additionalProperties": true,
            "default": { }
        }
    },
    "additionalProperties": false
}