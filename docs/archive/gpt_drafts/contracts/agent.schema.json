{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Agent",
    "type": "object",
    "required": [
        "id",
        "name",
        "role",
        "status"
    ],
    "properties": {
        "id": {
            "type": "string"
        },
        "name": {
            "type": "string"
        },
        "role": {
            "type": "string",
            "enum": [
                "router",
                "security",
                "infrastructure",
                "operations",
                "consensus"
            ]
        },
        "status": {
            "type": "string",
            "enum": [
                "active",
                "inactive"
            ]
        },
        "memory_size": {
            "type": "integer",
            "minimum": 0
        }
    },
    "additionalProperties": false
}